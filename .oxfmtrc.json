{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "trailingComma": "all",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules",
    ".pnpm-store",
    "dist",
    "build",
    ".vite",
    "*.local",
    "*.log",
    "logs",
    ".vscode",
    ".idea",
    "*.swp",
    "*.swo",
    ".DS_Store",
    "Thumbs.db",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "coverage",
    ".nyc_output",
    "old"
  ]
}
